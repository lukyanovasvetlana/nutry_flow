# Supabase Configuration
# Получите эти значения в Supabase Dashboard: Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Firebase Configuration
# Получите эти значения в Firebase Console: Project Settings
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_ANDROID_APP_ID=your_firebase_android_app_id
FIREBASE_IOS_APP_ID=your_firebase_ios_app_id

# Analytics Configuration
# Получите токен в Mixpanel Dashboard: Settings → Project Settings
MIXPANEL_TOKEN=your_mixpanel_token_here

# Примечание:
# 1. Скопируйте этот файл: cp .env.example .env
# 2. Заполните реальные значения в .env файле
# 3. НИКОГДА не коммитьте .env файл в репозиторий!
